# ============================================
# NexoCRM - Production Environment Variables
# ============================================
# 
# ⚠️ IMPORTANTE: Não commita este arquivo no Git!
# Este é um template. Substitua os valores com seus próprios.
#

# ========== DATABASE ==========
# Endpoint RDS (obtém no AWS Console → RDS → Databases → nexocrm-prod)
# Formato: mysql://usuario:senha@host:porta/database
DATABASE_URL=mysql://admin:sua-senha-forte-aqui@nexocrm-prod.c9akciq32.us-east-1.rds.amazonaws.com:3306/nexocrm

# Senha do usuário root do MySQL (mesma que você configurou no RDS)
MYSQL_ROOT_PASSWORD=sua-senha-forte-aqui

# ========== AUTHENTICATION ==========
# JWT Secret: Gere com: openssl rand -hex 48
# Mude este valor ANTES de fazer deploy em produção!
JWT_SECRET=seu-secret-aleatorio-de-96-caracteres-gere-um-com-openssl-rand-hex-48

# ========== ENVIRONMENT ==========
# Ambiente: development | staging | production
NODE_ENV=production

# Porta do servidor (geralmente 3001)
API_PORT=3001

# ========== FRONTEND URL ==========
# URL onde o frontend estará hospedado (com HTTPS)
FRONTEND_URL=https://yourdomain.com

# ========== FRONTEND ENV VARS ==========
# (Estes devem estar em frontend/.env.production.local também)
# URL da API do backend (com HTTPS)
NEXT_PUBLIC_API_URL=https://api.yourdomain.com

# ========== OPTIONAL: AWS/CDN ==========
# Se usar S3/CloudFront para assets:
# AWS_ACCESS_KEY_ID=sua-chave-aqui
# AWS_SECRET_ACCESS_KEY=seu-secret-aqui
# AWS_S3_BUCKET=nexocrm-frontend
# AWS_REGION=us-east-1

# ========== OPTIONAL: EMAIL ==========
# Para notificações, recuperação de senha, etc:
# SMTP_HOST=smtp.seu-provedor.com
# SMTP_PORT=587
# SMTP_USER=seu-email@yourdomain.com
# SMTP_PASSWORD=sua-senha-smtp
# SMTP_FROM=noreply@yourdomain.com

# ========== OPTIONAL: OBSERVABILITY ==========
# Para logs e monitoramento:
# SENTRY_DSN=https://seu-sentry-key@sentry.io/projeto-id
# LOG_LEVEL=info
